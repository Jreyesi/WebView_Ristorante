generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id        Int        @id @default(autoincrement())
  name      String
  menuItems MenuItem[]
}

model MenuItem {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  price       String
  imageUrl    String?
  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id])
}

model User {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
}

model About {
  id          Int    @id @default(autoincrement())
  title       String
  intro       String
  body        String
  imageUrl    String
  val1Icon    String
  val1Title   String
  val1Desc    String
  val2Icon    String
  val2Title   String
  val2Desc    String
  val3Icon    String
  val3Title   String
  val3Desc    String
}

model Reservation {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String
  people    Int
  date      String
  time      String
  message   String?
  status    String   @default("Pendiente")
  createdAt DateTime @default(now())
}

model PriceItem {
  id        Int      @id @default(autoincrement())
  name      String
  range     String
  icon      String
  desc      String
}

model Contact {
  id        Int      @id @default(autoincrement())
  address   String
  phone     String
  email     String
  schedule  String
}
